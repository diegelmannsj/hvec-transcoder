# --- Configuration & Constants ---
LOG_DIR = "/storage/megawd/tv/.logs"
TARGET_LOUDNESS = -23.0
TARGET_TRUE_PEAK = -2.0

# Colors for terminal output
RED = "\033[91m"
GREEN = "\033[92m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
RESET = "\033[0m"

def check_dependencies():
    """Ensure required external tools are installed."""
    deps = ['ffmpeg', 'ffprobe', 'mkvmerge']
    missing = []
    for dep in deps:
        if shutil.which(dep) is None:
            missing.append(dep)
    if missing:
        tqdm.write(f"{RED}Error: Missing required dependencies: {', '.join(missing)}{RESET}", file=sys.stderr)
        sys.exit(1)

def run_command(cmd: List[str], desc: str = "Processing", show_output: bool = False, is_batch: bool = False) -> bool:
    """Run a shell command with a tqdm progress bar or live output."""
    try:
        if show_output:
            tqdm.write(f"{CYAN}--- {desc} ---{RESET}")
            subprocess.run(cmd, check=True)
            return True
        else:
            # For ffmpeg/mkvmerge, we could parse progress, but for simplicity we show a spinner or indeterminate bar
            # unless it's a fast operation
            with subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True) as proc:
                with tqdm(total=100, desc=desc, bar_format="{l_bar}{bar}| {n_fmt}/{total_fmt}", leave=not is_batch) as pbar:
                    # Very basic simulated progress for indeterminate tasks
                    for line in proc.stdout:
                        # If we wanted to parse FFmpeg time, we'd do it here. For now, just step the bar slightly to show activity.
                        pbar.update(0.1)
                        if pbar.n >= 99:
                            pbar.n = 0 
                            pbar.refresh()
                proc.wait()
                if proc.returncode != 0:
                    tqdm.write(f"{RED}Command failed with exit code {proc.returncode}{RESET}", file=sys.stderr)
                    return False
            return True
    except subprocess.CalledProcessError as e:
        tqdm.write(f"{RED}Error executing {cmd[0]}: {e}{RESET}", file=sys.stderr)
        return False
    except FileNotFoundError:
        tqdm.write(f"{RED}Command not found: {cmd[0]}{RESET}", file=sys.stderr)
        return False
    except KeyboardInterrupt:
        tqdm.write(f"\n{RED}Process interrupted by user.{RESET}", file=sys.stderr)
        sys.exit(1)

def get_media_info(file_path: str) -> Dict[str, Any]:
    """Use ffprobe to get media streams information."""
    cmd = [
        'ffprobe', '-v', 'quiet', '-print_format', 'json', '-show_streams', '-show_format', file_path
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout)
    except subprocess.CalledProcessError as e:
        tqdm.write(f"{RED}Error running ffprobe on {file_path}: {e}{RESET}", file=sys.stderr)
        return {}

def analyze_audio_loudness(file_path: str, stream_index: int) -> Dict[str, float]:
    """Analyze audio stream for LUFS and True Peak."""
    tqdm.write(f"{CYAN}Analyzing audio stream #{stream_index} for loudness...{RESET}")
    cmd = [
        'ffmpeg', '-hide_banner', '-i', file_path, '-map', f'0:{stream_index}',
        '-af', 'ebur128=framelog=verbose:peak=true', '-f', 'null', '-'
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        output = result.stderr
        
        # Parse the output
        i_match = re.search(r'I:\s+(-?\d+\.\d+)\s+LUFS', output)
        tp_match = re.search(r'True peak:\s+(-?\d+\.\d+)\s+dBTP', output)
        lra_match = re.search(r'LRA:\s+(\d+\.\d+)\s+LU', output)
        thresh_match = re.search(r'Threshold:\s+(-?\d+\.\d+)\s+LUFS', output)

        if i_match and tp_match:
            return {
                'i': float(i_match.group(1)),
                'tp': float(tp_match.group(1)),
                'lra': float(lra_match.group(1)) if lra_match else 0.0,
                'thresh': float(thresh_match.group(1)) if thresh_match else 0.0
            }
        else:
            tqdm.write(f"{YELLOW}Could not parse loudness data.{RESET}")
            return {}
    except subprocess.CalledProcessError as e:
         tqdm.write(f"{RED}Error analyzing audio: {e}{RESET}", file=sys.stderr)
         return {}

def append_to_loudness_log(file_name: str, pre_data: Dict[str, float], post_data: Dict[str, float], log_file: str):
    """Append loudness data to CSV log."""
    file_exists = os.path.isfile(log_file)
    os.makedirs(os.path.dirname(log_file), exist_ok=True)
    
    with open(log_file, mode='a', newline='') as f:
        fieldnames = ['Timestamp', 'Filename', 'Pre_I(LUFS)', 'Pre_TP(dBTP)', 'Pre_LRA', 'Post_I(LUFS)', 'Post_TP(dBTP)', 'Post_LRA']
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        
        if not file_exists:
            writer.writeheader()
            
        writer.writerow({
            'Timestamp': time.strftime("%Y-%m-%d %H:%M:%S"),
            'Filename': os.path.basename(file_name),
            'Pre_I(LUFS)': pre_data.get('i', ''),
            'Pre_TP(dBTP)': pre_data.get('tp', ''),
            'Pre_LRA': pre_data.get('lra', ''),
            'Post_I(LUFS)': post_data.get('i', ''),
            'Post_TP(dBTP)': post_data.get('tp', ''),
            'Post_LRA': post_data.get('lra', '')
        })

def extract_eia608_subtitles(input_file: str, temp_srt: str) -> bool:
    """Extract EIA-608 closed captions to an SRT file using lavfi."""
    tqdm.write(f"{CYAN}Checking for embedded EIA-608 captions...{RESET}")
    # Create symlink to handle bad paths
    sym_path = f"/tmp/hvec_temp_{os.getpid()}.ts"
    try:
        os.symlink(os.path.abspath(input_file), sym_path)
    except OSError as e:
         tqdm.write(f"{YELLOW}Failed to create symlink for CC extraction: {e}{RESET}")
         sym_path = input_file

    cmd = [
        'ffmpeg', '-y', '-hide_banner', '-f', 'lavfi',
        '-i', f'movie={sym_path}[out0+subcc]',
        '-map', '0:1', temp_srt
    ]
    
    success = False
    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0 and os.path.exists(temp_srt) and os.path.getsize(temp_srt) > 100:
            tqdm.write(f"{GREEN}Successfully extracted EIA-608 captions.{RESET}")
            success = True
        else:
            tqdm.write(f"{YELLOW}No EIA-608 captions found or extraction failed.{RESET}")
    except Exception as e:
        tqdm.write(f"{YELLOW}Exception during CC extraction: {e}{RESET}")
    finally:
        if sym_path != input_file and os.path.exists(sym_path):
            os.remove(sym_path)
            
    return success

def setup_permissions(path: str):
    """Set correct ownership and permissions for the output file."""
    try:
        # Set 664 permissions
        os.chmod(path, 0o664)
        # Attempt to set group to 'media' (if it exists)
        try:
            media_gid = grp.getgrnam('media').gr_gid
            os.chown(path, -1, media_gid)
        except KeyError:
            pass # Group 'media' doesn't exist, ignore
    except OSError as e:
        tqdm.write(f"{YELLOW}Warning: Could not set permissions on {path}: {e}{RESET}")

def main():
    print(f"[,hvec v{__version__}]")
    
    parser = argparse.ArgumentParser(description="Advanced Video Transcoder & Remuxer (QSV Accelerated)", formatter_class=argparse.RawTextHelpFormatter)
    
    # Input/Output
    parser.add_argument('-i', '--input', nargs='+', required=True, help="Input file(s) to process. Accepts wildcards.")
    parser.add_argument('-o', '--output', help="Output file (only valid for single file processing)")
    
    # Modes
    parser.add_argument('--remux', action='store_true', help="Remux video instead of transcoding (copy video stream)")
    parser.add_argument('--encode', action='store_true', help="Transcode video to HEVC using Intel QSV")
    parser.add_argument('--profile', choices=['normalize'], help="Apply predefined processing profile (e.g., 'normalize' implies -N -r -S -D)")
    
    # Audio
    parser.add_argument('--english', action='store_true', help="Keep only English audio streams")
    parser.add_argument('-N', '--normalize', action='store_true', help="Normalize primary audio stream to ATSC A/85 standards (-23 LUFS)")
    
    # File Operations
    parser.add_argument('-S', '--suffix-remove', action='store_true', help="Remove scene release suffixes from output filename")
    parser.add_argument('-D', '--delete', action='store_true', help="Delete original file after successful processing")
    parser.add_argument('-Y', '--assume-yes', action='store_true', help='Assume "yes" to all prompts and run non-interactively')
    
    # Utilities
    parser.add_argument('--version', action='version', version=f'%(prog)s {__version__}', help="Show version and exit")
    parser.add_argument('--history', action='store_true', help="Show detailed version history and exit")

    argcomplete.autocomplete(parser)
    args = parser.parse_args()

    if args.history:
        print(VERSION_HISTORY)
        sys.exit(0)

    if not args.remux and not args.encode and not args.profile:
        tqdm.write(f"{RED}Error: You must specify a mode: --remux, --encode, or --profile{RESET}", file=sys.stderr)
        sys.exit(1)

    is_batch_mode = len(args.input) > 1
    if is_batch_mode and args.output:
        tqdm.write(f"{RED}Error: Cannot specify --output when processing multiple files.{RESET}", file=sys.stderr)
        sys.exit(1)

    check_dependencies()

    # Profile handling
    is_normalize_enabled = args.normalize
    is_remux_enabled = args.remux
    is_encode_enabled = args.encode
    is_delete_enabled = args.delete
    is_suffix_remove = args.suffix_remove

    if args.profile == 'normalize':
        is_normalize_enabled = True
        is_remux_enabled = True
        is_suffix_remove = True
        is_delete_enabled = True
        tqdm.write(f"{CYAN}Loaded Profile: 'normalize' (Remux, Normalize Audio, Remove Suffix, Delete Original){RESET}")

    # Initialize batch memory for multi-channel normalization choices
    global_normalize_multichannel = None

    files_to_process = args.input
    failed_files = []

    # Prepare Loudness Log
    active_log_file = None
    if is_normalize_enabled:
        date_str = time.strftime("%Y-%m")
        active_log_file = os.path.join(LOG_DIR, f"loudness_log_{date_str}.csv")

    with tqdm(total=len(files_to_process), desc="Total Progress", disable=not is_batch_mode) as batch_bar:
        for input_file in files_to_process:
            if not os.path.isfile(input_file):
                tqdm.write(f"{YELLOW}Warning: File not found: {input_file}. Skipping.{RESET}")
                failed_files.append(input_file)
                if is_batch_mode: batch_bar.update(1)
                continue

            tqdm.write(f"\n--- Processing: {os.path.basename(input_file)} ---")
            
            media_info = get_media_info(input_file)
            if not media_info or 'streams' not in media_info:
                tqdm.write(f"{RED}Error: Could not read media info. Skipping.{RESET}")
                failed_files.append(input_file)
                if is_batch_mode: batch_bar.update(1)
                continue

            video_streams = []
            audio_streams = []
            subtitle_streams = []

            for i, stream in enumerate(media_info['streams']):
                codec_type = stream.get('codec_type')
                if codec_type == 'video':
                    video_streams.append(stream)
                elif codec_type == 'audio':
                    audio_streams.append(stream)
                elif codec_type == 'subtitle':
                    subtitle_streams.append(stream)

            # Build Stream Selection Plan
            kept_streams = []
            removed_streams = []
            
            # Video
            if video_streams:
                kept_streams.append((video_streams[0]['index'], 'Video', video_streams[0].get('codec_name', 'unknown')))
            else:
                tqdm.write(f"{RED}Error: No video stream found. Skipping.{RESET}")
                failed_files.append(input_file)
                if is_batch_mode: batch_bar.update(1)
                continue

            # Audio
            target_audio_index = -1
            audio_channels = 2
            for stream in audio_streams:
                tags = stream.get('tags', {})
                lang = tags.get('language', 'unknown')
                
                keep_audio = True
                if args.english and lang not in ['eng', 'unknown']:
                    keep_audio = False
                    
                if keep_audio:
                    if target_audio_index == -1:
                        target_audio_index = stream['index']
                        audio_channels = stream.get('channels', 2)
                    kept_streams.append((stream['index'], f"Audio: {tags.get('title', 'Unknown')} [{lang}]", stream.get('codec_name', 'unknown')))
                else:
                    removed_streams.append((stream['index'], f"Audio: {tags.get('title', 'Unknown')} [{lang}]", stream.get('codec_name', 'unknown')))

            # Display Plan
            tqdm.write(f"\n{CYAN}--- Stream Selection Plan ---{RESET}")
            tqdm.write(f"{GREEN}KEPT:{RESET}")
            for idx, desc, codec in kept_streams:
                tqdm.write(f"  - Stream #{idx} ({desc}) [{codec}]")
                
            if removed_streams:
                tqdm.write(f"\n{RED}REMOVED:{RESET}")
                for idx, desc, codec in removed_streams:
                    tqdm.write(f"  - Stream #{idx} ({desc}) [{codec}]")

            # Check Assume Yes Flag
            if getattr(args, 'assume_yes', False):
                tqdm.write("Proceed? [y/N]: y (auto-assumed via -Y)")
                proceed_choice = 'y'
            else:
                proceed_choice = input("Proceed? [y/N]: ")
                
            if proceed_choice.lower() != 'y':
                tqdm.write(f"{YELLOW}Skipping {input_file}{RESET}")
                if is_batch_mode: batch_bar.update(1)
                continue

            mode_str = "Lossless Video Remux" if is_remux_enabled else "HEVC QSV Encode"
            tqdm.write(f"Mode: {mode_str}")

            # Subtitle Extraction
            temp_files_to_cleanup = []
            extracted_srt = None
            if input_file.lower().endswith('.ts'):
                extracted_srt = f"/tmp/hvec_subs_{os.getpid()}.srt"
                if extract_eia608_subtitles(input_file, extracted_srt):
                    temp_files_to_cleanup.append(extracted_srt)
                else:
                    extracted_srt = None

            # Audio Normalization Prep
            audio_filter_str = None
            analysis_data = None
            audio_normalized = False
            
            if is_normalize_enabled and target_audio_index != -1:
                # Handle multi-channel downmix or retention
                proceed_norm = True
                if audio_channels > 2:
                    if getattr(args, 'assume_yes', False):
                        choice = 'd'
                        tqdm.write(f"{YELLOW}Multi-channel audio detected. Auto-assumed Downmix to Stereo (d) via -Y.{RESET}")
                    elif global_normalize_multichannel is not None:
                        choice = global_normalize_multichannel
                        tqdm.write(f"Applying batch multichannel choice: '{choice}'")
                    else:
                        tqdm.write(f"{YELLOW}Warning: Audio has {audio_channels} channels. Normalization works best on stereo.{RESET}")
                        choice = input("Downmix to Stereo (d), Keep Multichannel (k), or Skip Normalization (s)? [d/k/s/D(All)/K(All)]: ").lower()
                        if choice == 'd(all)' or choice == 'd':
                             if choice == 'd(all)': global_normalize_multichannel = 'd'
                             choice = 'd'
                        elif choice == 'k(all)' or choice == 'k':
                             if choice == 'k(all)': global_normalize_multichannel = 'k'
                             choice = 'k'
                        
                    if choice == 's':
                        proceed_norm = False
                    elif choice == 'd':
                        audio_filter_str = f"pan=stereo|FL=0.5*FC+0.707*FL+0.707*BL+0.5*LFE|FR=0.5*FC+0.707*FR+0.707*BR+0.5*LFE,loudnorm=I={TARGET_LOUDNESS}:TP={TARGET_TRUE_PEAK}"
                    else: # 'k'
                        audio_filter_str = f"loudnorm=I={TARGET_LOUDNESS}:TP={TARGET_TRUE_PEAK}"
                else:
                    audio_filter_str = f"loudnorm=I={TARGET_LOUDNESS}:TP={TARGET_TRUE_PEAK}"

                if proceed_norm:
                    analysis_data = analyze_audio_loudness(input_file, target_audio_index)
                    if analysis_data:
                        tqdm.write(f"Pre-Norm LUFS: {analysis_data.get('i')} | TP: {analysis_data.get('tp')}")
                        # Linear integration if needed, but loudnorm handles dynamic range automatically
                        audio_normalized = True

            # Determine Output Filename
            base_name = os.path.basename(input_file)
            name_no_ext, _ = os.path.splitext(base_name)
            
            if is_suffix_remove:
                # Simple regex to strip typical release group suffixes (e.g., -GROUP)
                name_no_ext = re.sub(r'-[a-zA-Z0-9]+$', '', name_no_ext)
                
            if args.output:
                final_output_file = args.output
            else:
                final_output_file = os.path.join(os.path.dirname(input_file), f"{name_no_ext}.mkv")
                
            # Prevent overwriting input directly
            temp_output_file = final_output_file
            if os.path.abspath(input_file) == os.path.abspath(final_output_file):
                temp_output_file = final_output_file + ".tmp.mkv"
                temp_files_to_cleanup.append(temp_output_file)

            # Build FFmpeg Command
            ffmpeg_cmd = ['ffmpeg', '-y', '-hide_banner']
            
            # QSV Decoding
            if is_encode_enabled or (is_remux_enabled and input_file.lower().endswith('.ts')):
                # Use QSV for decoding if possible, enforce nv12 for robustness against resolution changes
                ffmpeg_cmd.extend(['-hwaccel', 'qsv', '-hwaccel_output_format', 'nv12'])
                
            ffmpeg_cmd.extend(['-i', input_file])
            
            if extracted_srt:
                ffmpeg_cmd.extend(['-i', extracted_srt])

            # Map kept streams
            for idx, _, _ in kept_streams:
                ffmpeg_cmd.extend(['-map', f'0:{idx}'])
                
            if extracted_srt:
                # Map the new subtitle stream
                ffmpeg_cmd.extend(['-map', '1:0'])

            # Video Encoding Settings
            if is_remux_enabled:
                ffmpeg_cmd.extend(['-c:v', 'copy'])
            else:
                ffmpeg_cmd.extend(['-c:v', 'hevc_qsv', '-preset', 'slow', '-global_quality', '23'])
                
            # Audio Encoding Settings
            if audio_normalized:
                ffmpeg_cmd.extend(['-c:a', 'aac', '-b:a', '192k', '-af', audio_filter_str])
            else:
                ffmpeg_cmd.extend(['-c:a', 'copy'])

            # Subtitle Settings
            ffmpeg_cmd.extend(['-c:s', 'copy'])
            
            # Metadata passthrough
            ffmpeg_cmd.extend(['-map_metadata', '0', '-map_chapters', '0'])
            
            if extracted_srt:
                # Set metadata for the newly added SRT track (assuming it's the last stream mapped)
                srt_stream_idx = len(kept_streams) # 0-indexed offset based on mapped streams
                ffmpeg_cmd.extend([f'-metadata:s:s:{srt_stream_idx - 1}', 'language=eng', f'-metadata:s:s:{srt_stream_idx - 1}', 'title=English (CC)'])

            ffmpeg_cmd.append(temp_output_file)

            # Execute
            success = run_command(ffmpeg_cmd, desc=f"Processing {base_name}", is_batch=is_batch_mode)
            
            if not success:
                failed_files.append(input_file)
            else:
                # File replacements and cleanup
                setup_permissions(temp_output_file)
                
                if temp_output_file != final_output_file:
                    try:
                        shutil.move(temp_output_file, final_output_file)
                        setup_permissions(final_output_file)
                    except OSError as e:
                        tqdm.write(f"Error: Could not move temp file: {e}", file=sys.stderr)
                        success = False
                
                if success:
                    tqdm.write(f"{GREEN}Successfully processed: {final_output_file}{RESET}")
                    if is_delete_enabled and os.path.abspath(input_file) != os.path.abspath(final_output_file):
                        try:
                            os.remove(input_file)
                            tqdm.write(f"Deleted original file: {input_file}")
                        except OSError as e:
                             tqdm.write(f"{YELLOW}Warning: Could not delete original file: {e}{RESET}")
                             
                    # Update Loudness Log if applicable
                    if is_normalize_enabled and audio_normalized and active_log_file and analysis_data:
                        try:
                            post_norm_data = {
                                'i': TARGET_LOUDNESS,
                                'tp': TARGET_TRUE_PEAK,
                                'lra': analysis_data.get('lra', 0.0), # Assuming LRA stays roughly similar or is handled by loudnorm
                                'thresh': analysis_data.get('thresh', 0.0)
                            }
                            append_to_loudness_log(final_output_file, analysis_data, post_norm_data, active_log_file)
                        except Exception as e:
                            tqdm.write(f"{YELLOW}Warning: Could not update loudness log: {e}{RESET}", file=sys.stderr)

            # Cleanup any temporary subtitle extraction files
            for tf in temp_files_to_cleanup:
                if os.path.exists(tf):
                    try: os.remove(tf)
                    except OSError: pass

            if is_batch_mode:
                batch_bar.update(1)

    tqdm.write("\n--- All tasks complete. ---")
    
    if failed_files:
        tqdm.write(f"\n{RED}--- Failed Files ({len(failed_files)}) ---{RESET}")
        for f in failed_files:
            tqdm.write(f"{RED}  - {os.path.basename(f)}{RESET}")

if __name__ == "__main__":
    main()